# Truffle — local test & benchmark environment.
# Copy to `.env` (which is gitignored) and fill in values.
#
# Without TRUFFLE_TEST_AUTHKEY set, real-network tests and benchmarks
# will skip gracefully. Mock-based tests and micro benchmarks always run.
#
# How to get an auth key:
#   1. Go to https://login.tailscale.com/admin/settings/keys
#   2. Generate an auth key with: Reusable, Ephemeral, Tags: tag:truffle-test
#      (and Pre-approved if device approval is enabled on your tailnet)
#   3. Ensure your tailnet ACL grants `tag:truffle-test` as an ownerless tag.
#      See docs/TESTING.md for a snippet.
#
# See docs/TESTING.md for the full walkthrough.

# REQUIRED for real-network tests & benches. Leave unset to skip them.
TRUFFLE_TEST_AUTHKEY=

# Optional overrides (defaults shown):
# TRUFFLE_TEST_TAGS=      # comma-separated tags to advertise. LEAVE UNSET
                          # unless your tailnet ACL has a matching tagOwners
                          # entry — the auth key's own tag applies
                          # automatically. Set only for explicit overrides.
# TRUFFLE_TEST_EPHEMERAL=true
# TRUFFLE_TEST_LOG=truffle_core=info
# TRUFFLE_TEST_STATE_ROOT=
