{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "component": "truffle",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        {
          "type": "cargo-workspace",
          "path": "crates/truffle-cli/Cargo.toml"
        },
        {
          "type": "cargo-workspace",
          "path": "crates/truffle-core/Cargo.toml"
        },
        {
          "type": "json",
          "path": "npm/truffle-sidecar-darwin-arm64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/truffle-sidecar-darwin-x64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/truffle-sidecar-linux-arm64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/truffle-sidecar-linux-x64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/truffle-sidecar-win32-x64/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}