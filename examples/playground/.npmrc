# Force pnpm to resolve @vibecook/truffle (and its transitive deps) from
# the npm registry instead of linking to the local workspace package.
# This makes the playground a faithful reproduction of how an external
# consumer would install and run the example.
link-workspace-packages=false
prefer-workspace-packages=false

# NOTE for external consumers: pnpm 10 blocks postinstall scripts by
# default. If you copy this example out of the monorepo, add the
# following to your root package.json so @vibecook/truffle can run
# its postinstall (which chmods the sidecar binary):
#
#   "pnpm": { "onlyBuiltDependencies": ["@vibecook/truffle"] }
