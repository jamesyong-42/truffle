# Force pnpm to resolve @vibecook/truffle (and its native / sidecar
# transitive deps) from the npm registry instead of linking to the
# local workspace packages. This makes the playground a faithful
# reproduction of the experience an external consumer gets when they
# `npm install @vibecook/truffle`, and it means the playground can
# run on a fresh clone on any platform without needing a Rust
# toolchain to build @vibecook/truffle-native locally.
link-workspace-packages=false
prefer-workspace-packages=false
