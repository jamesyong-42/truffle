{
  "name": "@vibecook/truffle-native",
  "version": "0.1.1",
  "description": "Mesh networking for local-first apps, built on Tailscale (native addon)",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "author": "James Yong",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesyong-42/truffle.git",
    "directory": "crates/truffle-napi"
  },
  "homepage": "https://github.com/jamesyong-42/truffle#readme",
  "bugs": {
    "url": "https://github.com/jamesyong-42/truffle/issues"
  },
  "keywords": [
    "mesh",
    "networking",
    "tailscale",
    "local-first",
    "p2p",
    "napi",
    "rust"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "index.js",
    "index.d.ts",
    "helpers.js",
    "helpers.d.ts",
    "*.node"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./helpers": {
      "types": "./helpers.d.ts",
      "default": "./helpers.js"
    }
  },
  "napi": {
    "binaryName": "truffle",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "aarch64-linux-android",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "armv7-unknown-linux-gnueabihf"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "artifacts": "napi artifacts"
  }
}