{
  "name": "@vibecook/truffle-react",
  "version": "0.3.22",
  "description": "React hooks for Truffle mesh networking",
  "license": "MIT",
  "author": "James Yong",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesyong-42/truffle.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/jamesyong-42/truffle#readme",
  "bugs": {
    "url": "https://github.com/jamesyong-42/truffle/issues"
  },
  "keywords": [
    "mesh",
    "networking",
    "tailscale",
    "local-first",
    "p2p",
    "react",
    "hooks"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vibecook/truffle": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  }
}
