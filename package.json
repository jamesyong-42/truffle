{
  "name": "@vibecook/truffle-root",
  "private": true,
  "version": "0.1.0",
  "description": "Standalone mesh networking library built on Tailscale",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesyong-42/truffle.git"
  },
  "homepage": "https://github.com/jamesyong-42/truffle#readme",
  "bugs": {
    "url": "https://github.com/jamesyong-42/truffle/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter '!@vibecook/truffle-docs' run build",
    "test": "pnpm -r run test",
    "test:rust": "cargo test --workspace",
    "test:real": "cargo test -p truffle-core --tests -- --nocapture",
    "test:all": "pnpm run test && pnpm run test:rust",
    "bench": "pnpm run bench:micro",
    "bench:micro": "cargo bench -p truffle-core",
    "bench:macro": "cargo run -p truffle-bench --release -- file-transfer --size 10M --iterations 5 && cargo run -p truffle-bench --release -- synced-store --scenario b1-sequential --ops 1000 && cargo run -p truffle-bench --release -- request-reply --count 500",
    "bench:macro:fast": "cargo run -p truffle-bench --release -- file-transfer --size 1M --iterations 3",
    "bench:file-transfer": "cargo run -p truffle-bench --release -- file-transfer",
    "bench:synced-store": "cargo run -p truffle-bench --release -- synced-store",
    "bench:request-reply": "cargo run -p truffle-bench --release -- request-reply",
    "run-all": "bash scripts/run-all-tests-and-benches.sh",
    "run-all:fast": "bash scripts/run-all-tests-and-benches.sh --fast",
    "build:sidecar": "cd packages/sidecar-slim && go build -o ../../crates/truffle-core/tests/test-sidecar .",
    "check:secrets": "bash scripts/check-for-secrets.sh",
    "clean": "pnpm -r run clean && rm -f packages/*/tsconfig.tsbuildinfo",
    "clean:bench": "rm -rf target/criterion target/bench-results",
    "typecheck": "pnpm run build",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'",
    "docs:dev": "pnpm --filter @vibecook/truffle-docs dev",
    "docs:build": "pnpm --filter @vibecook/truffle-docs build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@vibecook/truffle", "electron", "esbuild"]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
