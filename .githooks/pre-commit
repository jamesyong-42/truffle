#!/usr/bin/env bash
# Truffle pre-commit hook
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Catches issues that would otherwise only surface in CI:
#   1. NAPI binding drift — if crates/truffle-napi/src/ changed but
#      index.d.ts / index.js weren't regenerated (caused 0.3.17 pipeline
#      to ship stale types)
#   2. Workflow YAML parse errors
#   3. Rustfmt violations on staged Rust files
#   4. Prettier violations on staged TypeScript files in packages/
#   5. Doctests in crates/truffle/src/lib.rs (the only doctest in CI)
#      when truffle-core or the meta-crate changes
#
# Skip with: git commit --no-verify

set -euo pipefail

RED=$'\033[0;31m'
YELLOW=$'\033[0;33m'
GREEN=$'\033[0;32m'
NC=$'\033[0m'

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Collect staged files (added, copied, modified) — not deleted.
# Uses a single `git diff` call and parses inline so we stay compatible
# with macOS's default bash 3.2 (no `mapfile`).
staged_files="$(git diff --cached --name-only --diff-filter=ACM)"
if [ -z "$staged_files" ]; then
  exit 0
fi

fail=0

# ───────────────────────────────────────────────────────────────
# Check 1: NAPI binding drift
# ───────────────────────────────────────────────────────────────
napi_src_changed=0
while IFS= read -r f; do
  case "$f" in
    crates/truffle-napi/src/*.rs|crates/truffle-napi/Cargo.toml|crates/truffle-napi/build.rs)
      napi_src_changed=1
      break
      ;;
  esac
done <<< "$staged_files"

if [ "$napi_src_changed" -eq 1 ]; then
  echo "${YELLOW}[pre-commit] NAPI source changed — regenerating bindings...${NC}"
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "${RED}[pre-commit] pnpm not found — install it or skip with --no-verify${NC}"
    exit 1
  fi

  if ! (cd crates/truffle-napi && pnpm run build >/dev/null 2>&1); then
    echo "${RED}[pre-commit] NAPI build failed — run 'cd crates/truffle-napi && pnpm run build' to see errors${NC}"
    exit 1
  fi

  # If index.d.ts or index.js changed after regen, the commit is missing them
  if ! git diff --quiet -- crates/truffle-napi/index.d.ts crates/truffle-napi/index.js; then
    echo "${RED}[pre-commit] NAPI bindings are out of date.${NC}"
    echo "${RED}            Stage the regenerated files and commit again:${NC}"
    echo "            git add crates/truffle-napi/index.d.ts crates/truffle-napi/index.js"
    fail=1
  else
    echo "${GREEN}[pre-commit] NAPI bindings up to date.${NC}"
  fi
fi

# ───────────────────────────────────────────────────────────────
# Check 2: YAML sanity on staged workflow files
# Catches unquoted colons in `run:` scalars and other parse errors
# that would otherwise cause GitHub Actions to reject the workflow
# at startup (0s "failure" runs).
# ───────────────────────────────────────────────────────────────
yaml_files=""
yaml_count=0
while IFS= read -r f; do
  case "$f" in
    .github/workflows/*.yml|.github/workflows/*.yaml)
      yaml_files="$yaml_files $f"
      yaml_count=$((yaml_count + 1))
      ;;
  esac
done <<< "$staged_files"

if [ "$yaml_count" -gt 0 ]; then
  # Prefer python3 with PyYAML (standard on macOS + Linux dev boxes)
  if command -v python3 >/dev/null 2>&1 && python3 -c "import yaml" >/dev/null 2>&1; then
    yaml_fail=0
    for f in $yaml_files; do
      if ! err="$(python3 -c "import yaml,sys; yaml.safe_load(open(sys.argv[1]))" "$f" 2>&1)"; then
        echo "${RED}[pre-commit] YAML parse error in $f:${NC}"
        echo "$err" | tail -3 | sed 's/^/            /'
        yaml_fail=1
      fi
    done
    if [ "$yaml_fail" -eq 1 ]; then
      fail=1
    else
      echo "${GREEN}[pre-commit] Workflow YAML clean ($yaml_count file(s)).${NC}"
    fi
  else
    echo "${YELLOW}[pre-commit] python3+PyYAML not available — skipping YAML check${NC}"
  fi
fi

# ───────────────────────────────────────────────────────────────
# Check 3: Rustfmt on staged .rs files
# ───────────────────────────────────────────────────────────────
rust_files=""
rust_count=0
while IFS= read -r f; do
  case "$f" in
    *.rs)
      rust_files="$rust_files $f"
      rust_count=$((rust_count + 1))
      ;;
  esac
done <<< "$staged_files"

if [ "$rust_count" -gt 0 ]; then
  if ! command -v rustfmt >/dev/null 2>&1; then
    echo "${YELLOW}[pre-commit] rustfmt not found — skipping format check${NC}"
  else
    # --check returns non-zero if any file needs formatting
    # shellcheck disable=SC2086
    if ! rustfmt --edition 2021 --check $rust_files >/dev/null 2>&1; then
      echo "${RED}[pre-commit] Rust formatting issues. Run:${NC}"
      echo "            cargo fmt"
      fail=1
    else
      echo "${GREEN}[pre-commit] Rustfmt clean ($rust_count file(s)).${NC}"
    fi
  fi
fi

# ───────────────────────────────────────────────────────────────
# Check 4: Prettier on staged TypeScript files in packages/
# CI runs `prettier --check 'packages/*/src/**/*.ts'`, so mirror that.
# ───────────────────────────────────────────────────────────────
ts_files=""
ts_count=0
while IFS= read -r f; do
  case "$f" in
    packages/*/src/*.ts|packages/*/src/**/*.ts)
      ts_files="$ts_files $f"
      ts_count=$((ts_count + 1))
      ;;
  esac
done <<< "$staged_files"

if [ "$ts_count" -gt 0 ]; then
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "${YELLOW}[pre-commit] pnpm not found — skipping prettier check${NC}"
  else
    # shellcheck disable=SC2086
    if ! pnpm exec prettier --check $ts_files >/dev/null 2>&1; then
      echo "${RED}[pre-commit] Prettier formatting issues. Run:${NC}"
      echo "            pnpm exec prettier --write$ts_files"
      fail=1
    else
      echo "${GREEN}[pre-commit] Prettier clean ($ts_count file(s)).${NC}"
    fi
  fi
fi

# ───────────────────────────────────────────────────────────────
# Check 5: Doctest in crates/truffle/src/lib.rs
# This is the only doctest CI runs, and it broke twice during the
# RFC 017 migration because the meta-crate's quick-start example
# referenced API that no longer existed. Re-run it whenever the
# meta-crate, truffle-core's public Node API, or the lib.rs itself
# changes.
# ───────────────────────────────────────────────────────────────
doctest_relevant=0
while IFS= read -r f; do
  case "$f" in
    crates/truffle/src/lib.rs|crates/truffle/Cargo.toml|crates/truffle-core/src/node.rs|crates/truffle-core/src/lib.rs)
      doctest_relevant=1
      break
      ;;
  esac
done <<< "$staged_files"

if [ "$doctest_relevant" -eq 1 ]; then
  echo "${YELLOW}[pre-commit] Meta-crate or core Node API changed — running truffle doctest...${NC}"
  if ! cargo test -p truffle --doc --quiet >/dev/null 2>&1; then
    echo "${RED}[pre-commit] truffle doctest failed. Run:${NC}"
    echo "            cargo test -p truffle --doc"
    fail=1
  else
    echo "${GREEN}[pre-commit] truffle doctest passes.${NC}"
  fi
fi

# ───────────────────────────────────────────────────────────────
# Check 6: TypeScript build for packages/
# When any TS file in packages/, the NAPI .d.ts, or a package.json
# changes, run `pnpm run build` to catch type drift across the
# workspace. CI runs this in the `check` job's "Build" step; the
# RFC 017 migration broke packages/cli/dev.ts (deviceId rename)
# without anything local catching it.
# ───────────────────────────────────────────────────────────────
ts_build_relevant=0
while IFS= read -r f; do
  case "$f" in
    packages/*/src/*.ts|packages/*/src/**/*.ts|packages/*/package.json|crates/truffle-napi/index.d.ts|crates/truffle-napi/index.js)
      ts_build_relevant=1
      break
      ;;
  esac
done <<< "$staged_files"

if [ "$ts_build_relevant" -eq 1 ]; then
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "${YELLOW}[pre-commit] pnpm not found — skipping TS build check${NC}"
  else
    echo "${YELLOW}[pre-commit] packages/ or NAPI types changed — running pnpm build...${NC}"
    if ! pnpm run build >/tmp/truffle-precommit-build.log 2>&1; then
      echo "${RED}[pre-commit] TypeScript build failed. Last 20 lines:${NC}"
      tail -20 /tmp/truffle-precommit-build.log | sed 's/^/            /'
      echo "${RED}            Full log: /tmp/truffle-precommit-build.log${NC}"
      fail=1
    else
      echo "${GREEN}[pre-commit] pnpm build clean.${NC}"
    fi
  fi
fi

exit "$fail"
